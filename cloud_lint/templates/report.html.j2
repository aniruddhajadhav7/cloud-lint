<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cloud-Lint Report: {{ report.filename }}</title>
    <style>
        :root {
            --bg-primary: #0d1117;
            --bg-secondary: #161b22;
            --bg-card: #21262d;
            --border: #30363d;
            --text-primary: #e6edf3;
            --text-secondary: #8b949e;
            --accent-blue: #58a6ff;
            --accent-green: #3fb950;
            --accent-yellow: #d29922;
            --accent-red: #f85149;
            --accent-purple: #bc8cff;
            --accent-orange: #ffa657;
            --risk-critical: #f85149;
            --risk-high: #ffa657;
            --risk-medium: #d29922;
            --risk-low: #3fb950;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            margin: 0;
            padding: 0;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        header {
            border-bottom: 1px solid var(--border);
            padding-bottom: 1rem;
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 { margin: 0; font-size: 1.8rem; }
        h2 { font-size: 1.4rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-top: 2rem; }

        .badge {
            display: inline-block;
            padding: 0.25em 0.6em;
            font-size: 0.85em;
            font-weight: 600;
            line-height: 1;
            text-align: center;
            white-space: nowrap;
            vertical-align: baseline;
            border-radius: 0.375rem;
            border: 1px solid transparent;
        }

        .badge-success { background-color: rgba(63, 185, 80, 0.1); color: var(--accent-green); border-color: rgba(63, 185, 80, 0.4); }
        .badge-danger { background-color: rgba(248, 81, 73, 0.1); color: var(--accent-red); border-color: rgba(248, 81, 73, 0.4); }
        .badge-warning { background-color: rgba(210, 153, 34, 0.1); color: var(--accent-yellow); border-color: rgba(210, 153, 34, 0.4); }
        .badge-info { background-color: rgba(88, 166, 255, 0.1); color: var(--accent-blue); border-color: rgba(88, 166, 255, 0.4); }

        .grid-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1rem;
            text-align: center;
        }

        .card-value {
            font-size: 2rem;
            font-weight: bold;
            color: var(--text-primary);
            margin: 0.5rem 0;
        }

        .card-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .validation-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1rem;
        }

        .validation-item {
            display: flex;
            align-items: center;
            padding: 1rem;
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 6px;
        }

        .validation-icon {
            font-size: 1.5rem;
            margin-right: 1rem;
        }

        .timeline {
            position: relative;
            max-width: 800px;
            margin: 2rem 0;
            padding-left: 2rem;
            border-left: 2px solid var(--border);
        }

        .timeline-item {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .timeline-marker {
            position: absolute;
            left: -2.6rem;
            width: 1rem;
            height: 1rem;
            border-radius: 50%;
            background-color: var(--bg-secondary);
            border: 2px solid var(--accent-blue);
        }

        .timeline-content {
            background-color: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 1rem;
        }

        .timeline-stage {
            font-weight: bold;
            color: var(--accent-blue);
            margin-bottom: 0.5rem;
            font-size: 0.9em;
            text-transform: uppercase;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1rem;
        }

        th, td {
            padding: 0.75rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        th {
            background-color: var(--bg-card);
            color: var(--text-secondary);
            font-weight: 600;
        }

        .accordion {
            background-color: var(--bg-card);
            color: var(--text-primary);
            cursor: pointer;
            padding: 1rem;
            width: 100%;
            text-align: left;
            border: 1px solid var(--border);
            outline: none;
            transition: 0.4s;
            border-radius: 6px;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }

        .active, .accordion:hover {
            background-color: var(--bg-secondary);
        }

        .panel {
            padding: 0 1rem;
            background-color: transparent;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.2s ease-out;
            margin-bottom: 1rem;
        }

        pre {
            background-color: var(--bg-card);
            padding: 1rem;
            border-radius: 6px;
            border: 1px solid var(--border);
            overflow-x: auto;
            color: var(--text-primary);
            font-size: 0.9em;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <div>
            <h1>☁ Cloud-Lint Report</h1>
            <div style="color: var(--text-secondary); margin-top: 0.5rem;">
                Target: {{ report.filename }} | Analyzed: {{ report.analyzed_at }}
            </div>
        </div>
        <div>
            {% if report.valid %}
            <span class="badge badge-success" style="font-size: 1.2rem;">PASS</span>
            {% else %}
            <span class="badge badge-danger" style="font-size: 1.2rem;">FAIL</span>
            {% endif %}
        </div>
    </header>

    <div class="grid-cards">
        <div class="card">
            <div class="card-label">Packages</div>
            <div class="card-value">{{ report.total_packages }}</div>
        </div>
        <div class="card">
            <div class="card-label">Users</div>
            <div class="card-value">{{ report.total_users }}</div>
        </div>
        <div class="card">
            <div class="card-label">Files</div>
            <div class="card-value">{{ report.total_files }}</div>
        </div>
        <div class="card">
            <div class="card-label">Commands</div>
            <div class="card-value">{{ report.total_commands }}</div>
        </div>
        <div class="card">
            <div class="card-label">Warnings</div>
            <div class="card-value" style="color: var(--accent-yellow)">{{ report.warnings_count }}</div>
        </div>
        <div class="card" style="border-color: var(--risk-{{ report.risk_level.value | lower }});">
            <div class="card-label">Risk Level</div>
            <div class="card-value" style="color: var(--risk-{{ report.risk_level.value | lower }})">{{ report.risk_level.value }}</div>
            <div style="font-size: 0.8rem; color: var(--text-secondary)">Score: {{ report.risk_score }}/100</div>
        </div>
    </div>

    <h2>Validation Status</h2>
    <div class="validation-grid">
        <div class="validation-item">
            <div class="validation-icon">
                {% if report.validation.yaml_valid %}✅{% else %}❌{% endif %}
            </div>
            <div>
                <strong>YAML Syntax</strong>
                <div style="font-size: 0.85em; color: var(--text-secondary)">Is the file valid YAML?</div>
            </div>
        </div>
        <div class="validation-item">
            <div class="validation-icon">
                {% if report.validation.schema_valid %}✅{% else %}❌{% endif %}
            </div>
            <div>
                <strong>Schema Validation</strong>
                <div style="font-size: 0.85em; color: var(--text-secondary)">Does it match cloud-init spec?</div>
            </div>
        </div>
        <div class="validation-item">
            <div class="validation-icon">
                {% if report.validation.cloud_init_compatible %}✅{% else %}⚠️{% endif %}
            </div>
            <div>
                <strong>Cloud-Init Compatible</strong>
                <div style="font-size: 0.85em; color: var(--text-secondary)">Has #cloud-config header?</div>
            </div>
        </div>
    </div>

    <h2>Execution Timeline</h2>
    <div class="timeline">
        {% for step in report.execution_steps %}
        <div class="timeline-item">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
                <div class="timeline-stage">{{ step.stage.value }} [{{ step.module }}]</div>
                <div>{{ step.icon }} {{ step.action }}</div>
                {% if step.details %}
                <ul style="margin: 0.5rem 0 0 0; padding-left: 1.5rem; color: var(--text-secondary); font-size: 0.9em;">
                    {% for detail in step.details %}
                    <li>{{ detail }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>

    <h2>Dependency Graph</h2>
    <div class="card" style="text-align: center; padding: 2rem;">
        <div class="mermaid">
{{ mermaid_dsl }}
        </div>
    </div>

    <h2>Risk Report</h2>
    {% if report.risk_items %}
    <table>
        <thead>
            <tr>
                <th>Level</th>
                <th>Context</th>
                <th>Command/Content</th>
                <th>Description / Suggestion</th>
            </tr>
        </thead>
        <tbody>
            {% for risk in report.risk_items %}
            <tr>
                <td><span class="badge" style="background-color: var(--risk-{{ risk.level.value | lower }}); color: #fff">{{ risk.level.value }}</span></td>
                <td><code style="font-size: 0.9em; color: var(--accent-purple)">{{ risk.context }}</code></td>
                <td><code style="font-size: 0.9em;">{{ risk.command }}</code></td>
                <td>
                    <div>{{ risk.description }}</div>
                    <div style="font-size: 0.85em; color: var(--text-secondary); margin-top: 0.3rem;">💡 {{ risk.suggestion }}</div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <div class="card" style="text-align: center; color: var(--accent-green);">
        ✅ No security risks detected.
    </div>
    {% endif %}

    {% if report.validation.warnings %}
    <h2>Warnings</h2>
    <div class="card" style="border-color: var(--accent-yellow)">
        <ul style="margin: 0; padding-left: 1.5rem; color: var(--text-secondary);">
            {% for w in report.validation.warnings %}
            <li style="margin-bottom: 0.5rem;">
                {% if w.field %}<strong style="color: var(--text-primary)">[{{ w.field }}]</strong>{% endif %}
                {{ w.message }}
                {% if w.suggestion %}<br><span style="font-size: 0.9em; color: var(--accent-yellow)">💡 {{ w.suggestion }}</span>{% endif %}
            </li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    <h2>Raw JSON</h2>
    <button class="accordion">Show JSON Output</button>
    <div class="panel">
        <pre><code class="language-json">{{ raw_json }}</code></pre>
    </div>

</div>

<!-- Mermaid.js -->
<script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
<script>
    mermaid.initialize({ 
        startOnLoad: true, 
        theme: 'dark',
        fontFamily: '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif'
    });

    // Accordion script
    var acc = document.getElementsByClassName("accordion");
    for (var i = 0; i < acc.length; i++) {
        acc[i].addEventListener("click", function() {
            this.classList.toggle("active");
            var panel = this.nextElementSibling;
            if (panel.style.maxHeight) {
                panel.style.maxHeight = null;
            } else {
                panel.style.maxHeight = panel.scrollHeight + "px";
            } 
        });
    }
</script>

</body>
</html>
